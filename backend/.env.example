# Copy to .env for local dev. On Render, set these in the dashboard.

PORT=3000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=milkman-s3-bucket

# Firebase Admin — paste full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional comma-separated origins (default allows all)
# CORS_ORIGINS=https://your-admin.onrender.com
